{
	"name": "io",
	"version": "3.1.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"packages/shared",
		"packages/daemon",
		"packages/tui",
		"packages/telegram",
		"packages/web"
	],
	"scripts": {
		"build": "npm run build --workspace=packages/shared && npm run build --workspace=packages/daemon --workspace=packages/tui --workspace=packages/telegram --workspace=packages/web",
		"build:docs": "cd docs && npm run build",
		"dev": "npm run dev --workspace=packages/daemon",
		"dev:tui": "npm run dev --workspace=packages/tui",
		"dev:docs": "cd docs && npm run dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write ."
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"typescript": "^5.7.0",
		"vitest": "^3.1.0"
	}
}
